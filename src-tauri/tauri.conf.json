{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Direct Light",
  "version": "0.7.1",
  "identifier": "com.oukeming64.directlight",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri"
  },
  "app": {
    "windows": [
      {
        "title": "Direct Light · 白棚灯光预演",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "GraphicsAndDesign",
    "copyright": "© 2026 Keming Ou",
    "shortDescription": "白棚灯光预演 / White-studio lighting previz",
    "longDescription": "Direct Light is a white-studio lighting previz sandbox for directors, DPs, and gaffers.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
